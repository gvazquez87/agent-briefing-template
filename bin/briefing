#!/usr/bin/env bash
# ------------------------------------------------
# briefing - personal agent context hub
#
# One private repo that carries your always-on directions, long-form memory,
# and reusable skills to every machine and every agent. The repo can live
# anywhere; every path is derived, nothing is hardcoded.
#
# Commands live in lib/cmd-*.sh; per-agent wiring lives in adapters/*.sh.
# ------------------------------------------------
set -euo pipefail

# Resolve the hub even when invoked through the ~/.local/bin symlink
HUB="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/briefing"
REG="$STATE_DIR/linked-projects"
DIRECTIONS="$HUB/directions/AGENTS.md"
export DRY_RUN="${DRY_RUN:-0}"

source "$HUB/lib/log.sh"
source "$HUB/lib/common.sh"

show_help() {
  cat <<'EOF'
briefing - personal agent context hub

Usage:
  briefing [-n|--dry-run] <command> [args]

Commands:
  install         wire every installed agent to this repo (idempotent)
  link <dir>      wire a project: skills manifest, HERMES.md mirror, Cursor rule
  sync [msg]      commit memory changes, pull --rebase, reinstall, push
  status          health check: global wiring, projects, repo state
  path            print where this repo lives
  help            show this message

Options:
  -n, --dry-run   print mutating actions instead of performing them
  -h, --help      show help (also per command: briefing <command> --help)

Exit codes:
  0 = success (status: everything healthy)
  1 = failure (status: something needs attention)
  2 = usage error
EOF
}

# Global flags
while [[ "${1:-}" == -* ]]; do
  case "$1" in
    -n|--dry-run) DRY_RUN=1; shift ;;
    -h|--help)    show_help; exit 0 ;;
    *) printf 'unknown option: %s\n\n' "$1" >&2; show_help >&2; exit 2 ;;
  esac
done

CMD="${1:-help}"; shift || true

case "$CMD" in
  install|link|sync|status|path)
    source "$HUB/lib/cmd-$CMD.sh"
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
      "cmd_${CMD}_help"
    else
      "cmd_$CMD" "$@"
    fi
    ;;
  help) show_help ;;
  *) printf 'unknown command: %s\n\n' "$CMD" >&2; show_help >&2; exit 2 ;;
esac
