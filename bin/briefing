#!/usr/bin/env bash
# ------------------------------------------------
# briefing - personal agent context hub
#
# One private repo that carries your always-on directions, long-form memory,
# and reusable skills to every machine and every agent. The repo can live
# anywhere; every path is derived, nothing is hardcoded.
#
# Commands live in lib/cmd-*.sh; per-agent wiring lives in adapters/*.sh.
# ------------------------------------------------
set -euo pipefail

# Resolve the hub even when invoked through the ~/.local/bin symlink.
# (a loop instead of `readlink -f`, which macOS only gained in 12.3)
SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do
  TARGET="$(readlink "$SELF")"
  [[ "$TARGET" == /* ]] || TARGET="$(dirname "$SELF")/$TARGET"
  SELF="$TARGET"
done
HUB="$(cd "$(dirname "$SELF")/.." && pwd)"
unset SELF TARGET
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/briefing"
REG="$STATE_DIR/linked-projects"
DIRECTIONS="$HUB/directions/AGENTS.md"
export DRY_RUN="${DRY_RUN:-0}"

source "$HUB/lib/log.sh"
source "$HUB/lib/common.sh"

show_help() {
  cat <<'EOF'
briefing - personal agent context hub

Usage:
  briefing [-n|--dry-run] <command> [args]

Commands:
  install         wire every installed agent to this repo (idempotent)
  adopt [file..]  import existing instruction files into directions/AGENTS.md
  link <dir>      wire a project: skills manifest, HERMES.md mirror, Cursor rule
  unlink <dir>    detach a project: remove generated files and hub-owned links
  sync [msg]      commit memory changes, pull --rebase, reinstall, push
  status          health check: global wiring, projects, repo state
  path            print where this repo lives
  uninstall       undo everything on this machine (the repo stays untouched)
  help            show this message

Options (accepted before or after the command):
  -n, --dry-run   print mutating actions instead of performing them
  -h, --help      show help (also per command: briefing <command> --help)
  -V, --version   print version and exit

Exit codes:
  0 = success (status: everything healthy)
  1 = failure (status: something needs attention)
  2 = usage error
EOF
}

# Flags are accepted anywhere (before or after the command); anything else
# starting with a dash is an error instead of being silently ignored.
CMD="" HELP=0 VERSION=0
ARGS=()
for arg in "$@"; do
  case "$arg" in
    -n|--dry-run) DRY_RUN=1 ;;
    -h|--help)    HELP=1 ;;
    -V|--version) VERSION=1 ;;
    -*) printf 'unknown option: %s\n\n' "$arg" >&2; show_help >&2; exit 2 ;;
    *)  if [[ -z "$CMD" ]]; then CMD="$arg"; else ARGS+=("$arg"); fi ;;
  esac
done
[[ -z "$CMD" ]] && CMD=help

if [[ "$VERSION" == 1 ]]; then
  printf 'briefing %s\n' "$(tr -d '[:space:]' < "$HUB/VERSION")"
  exit 0
fi

# One machine, one hub: refuse to judge or rewire state from a checkout that
# is not the registered hub. `briefing install` is the explicit adoption path.
check_hub_identity() {
  local registered
  registered="$(cat "$STATE_DIR/hub" 2>/dev/null || true)"
  if [[ -z "$registered" || "$registered" == "$HUB" ]]; then return 0; fi
  if [[ ! -e "$registered/bin/briefing" ]]; then return 0; fi   # registered hub is gone, carry on
  case "$1" in
    path) return 0 ;;   # read-only, answers about this checkout by design
    install) info "adopting $HUB as the hub (was: $registered)" ;;
    *) die "this checkout is not the registered hub
  running from:   $HUB
  registered hub: $registered
either run '$registered/bin/briefing $1' or adopt this checkout first with '$HUB/bin/briefing install'" ;;
  esac
}

case "$CMD" in
  install|adopt|link|unlink|sync|status|path|uninstall)
    source "$HUB/lib/cmd-$CMD.sh"
    if [[ "$HELP" == 1 ]]; then
      "cmd_${CMD}_help"
    else
      check_hub_identity "$CMD"
      "cmd_$CMD" ${ARGS[@]+"${ARGS[@]}"}
    fi
    ;;
  help) show_help ;;
  *) printf 'unknown command: %s\n\n' "$CMD" >&2; show_help >&2; exit 2 ;;
esac
